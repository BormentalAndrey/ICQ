QMAKE_PRL_TARGET = libQt6QmlDebug_arm64-v8a.a
QMAKE_PRL_CONFIG = static
QMAKE_PRL_VERSION = 6.5.0
QMAKE_PRL_LIBS = $$[QT_INSTALL_LIBS]/libQt6PacketProtocol_arm64-v8a.a $$[QT_INSTALL_LIBS]/libQt6Qml_arm64-v8a.so $$[QT_INSTALL_LIBS]/libQt6Network_arm64-v8a.so $$[QT_INSTALL_LIBS]/libQt6Core_arm64-v8a.so -llog -pthread
QMAKE_PRL_LIBS_FOR_CMAKE = $$[QT_INSTALL_LIBS]/libQt6PacketProtocol_arm64-v8a.a;$$[QT_INSTALL_LIBS]/libQt6Qml_arm64-v8a.so;$$[QT_INSTALL_LIBS]/libQt6Network_arm64-v8a.so;$$[QT_INSTALL_LIBS]/libQt6Core_arm64-v8a.so;-llog;-pthread
